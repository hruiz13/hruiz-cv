---
export interface Props {
	title: string;
	body?: string;
	href?: string;
}

const { href, title, body } = Astro.props;
const newTitle = title.split('/n')
---

<li class="link-card">
	<a href={href} class="card-link">
		<h2>
			{
				newTitle.map((t)=><>{t}<br></>)
			}
		</h2>
		<p>
			{body}
			<slot />
		</p>
	</a>
</li>
<style>
	.link-card {
		list-style: none;
		display: flex;
		min-height: 11rem;
	}

	.link-card > a {
		align-items: center;
		background:
			linear-gradient(#ffffff, #ffffff) padding-box,
			linear-gradient(135deg, rgba(214, 40, 40, 0.38), rgba(216, 243, 255, 0.8)) border-box;
		border: 1px solid transparent;
		border-radius: 8px;
		box-shadow: 0 18px 45px rgba(16, 33, 38, 0.08);
		color: #102126;
		display: flex;
		flex-direction: column;
		justify-content: center;
		line-height: 1.4;
		min-height: 100%;
		padding: 1.15rem;
		text-align: center;
		text-decoration: none;
		transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
		width: 100%;
	}
	h2 {
		margin: 0;
		font-size: 1rem;
		font-weight: 900;
		letter-spacing: 0.02em;
	}
	p {
		align-items: center;
		background:
			radial-gradient(circle at 24% 18%, rgba(216, 243, 255, 0.18), transparent 45%),
			linear-gradient(145deg, #102126, #071316);
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 8px;
		display: flex;
		justify-content: center;
		min-height: 6.5rem;
		margin-bottom: 0;
		margin-top: 0.85rem;
		padding: 0.85rem;
		width: 100%;
	}
	.link-card:is(:hover, :focus-within) {
		z-index: 1;
	}
	.link-card:is(:hover, :focus-within) > a {
		border-color: rgba(214, 40, 40, 0.4);
		box-shadow: 0 26px 60px rgba(16, 33, 38, 0.14);
		transform: translateY(-5px);
	}
	.link-card :global(svg) {
		filter: drop-shadow(0 10px 18px rgba(0, 0, 0, 0.22));
		max-height: 4.6rem;
		max-width: 4.6rem;
	}
	.link-card :global(svg path[fill="#000000"]),
	.link-card :global(svg path[fill="#000"]),
	.link-card :global(svg path[fill="#333"]),
	.link-card :global(svg path[fill-rule][fill="#333"]) {
		fill: #f8fafc;
	}
</style>
