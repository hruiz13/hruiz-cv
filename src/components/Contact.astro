<style>
    contact{
        background:
            radial-gradient(circle at 50% 0, rgba(216, 243, 255, 0.16), transparent 22rem),
            linear-gradient(180deg, #102126 0%, #071316 100%);
        color: var(--snow);
        display: block;
        padding: 5rem 1.25rem 4rem;
    }
    .about {
        margin: auto;
        width: 100%;
	}
    .mw1024{
        margin: auto;
        width: 100%;
		max-width: 1024px;
    }
    h2 {
        color: var(--snow);
        font-size: clamp(2.4rem, 5vw, 4rem);
        line-height: 1;
        text-align: center;
    }
    .divider {
        background: linear-gradient(90deg, transparent, var(--maple), #ffb703, transparent);
    }
    .contact-button {
        align-items: center;
        background: rgba(251, 251, 247, 0.09);
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 999px;
        color: var(--ice);
        cursor: pointer;
        display: flex;
        font-weight: 800;
        justify-content: center;
        padding: 0.95rem 1.2rem;
        transition: background-color 180ms ease, transform 180ms ease;
    }
    .contact-button:hover {
        background: var(--maple);
        color: #ffffff;
        transform: translateY(-2px);
    }
    a {
        text-decoration: none;
    }
    .social-links a {
        align-items: center;
        background: #f8fafc;
        border: 1px solid rgba(216, 243, 255, 0.65);
        border-radius: 8px;
        color: #071316;
        display: inline-flex;
        height: 3.25rem;
        justify-content: center;
        width: 3.25rem;
    }
    .social-links a:hover {
        background: var(--maple);
        color: #ffffff;
    }
</style>
