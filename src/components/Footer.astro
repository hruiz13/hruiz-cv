<footer>
    <div class="footer">
        <h2 data-i18n data-en="Thanks!" data-es="Gracias!">Thanks!</h2>
        <p data-i18n data-en="Built with frontend craft and a little northern air." data-es="Hecho con oficio frontend y un poco de aire del norte.">Built with frontend craft and a little northern air.</p>
    </div>
</footer>
<style>
    footer{
        background: #071316;
        color: rgba(251, 251, 247, 0.74);
        padding: 0 1.25rem 2.5rem;
    }
    .footer {
        align-items: center;
        border-top: 1px solid rgba(255, 255, 255, 0.12);
        display: flex;
        gap: 0.75rem;
        justify-content: space-between;
        margin: auto;
		max-width: 1024px;
        padding-top: 1.5rem;
        width: 100%;
	}
    h2 {
        color: #ffdd8a;
        font-size: 1.2rem;
        font-weight: 900;
        margin: 0;
    }
    p {
        margin: 0;
        text-align: right;
    }
    @media (max-width: 640px) {
        .footer {
            align-items: flex-start;
            flex-direction: column;
        }
        p {
            text-align: left;
        }
    }
</style>
