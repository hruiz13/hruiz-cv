---
const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
const homeHref = base;
const knowledgeHref = `${base}hobbies`;
const projectsHref = `${base}projects`;
---

<header class="site-header">
	<nav class="header" aria-label="Principal">
		<a class="brand" href={homeHref} aria-label="Home" data-i18n-aria data-en-aria="Home" data-es-aria="Inicio">
			<img src="https://www.hruiz.com/img/logo-hruiz.png" alt="Hruiz" />
			<span>Hector Ruiz</span>
		</a>
		<ul>
			<li><a href={homeHref} data-i18n data-en="Home" data-es="Inicio">Home</a></li>
			<li><a href={knowledgeHref} data-i18n data-en="Knowledge" data-es="Conocimientos">Knowledge</a></li>
			<li><a href={projectsHref} data-i18n data-en="Projects" data-es="Proyectos">Projects</a></li>
		</ul>
		<div class="language-switch" aria-label="Language">
			<button type="button" data-lang-option="en" aria-pressed="true">EN</button>
			<button type="button" data-lang-option="es" aria-pressed="false">ES</button>
		</div>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		background: rgba(7, 19, 22, 0.78);
		border-bottom: 1px solid rgba(255, 255, 255, 0.12);
		backdrop-filter: blur(18px);
	}
	.header {
		align-items: center;
		display: flex;
		justify-content: space-between;
		margin: auto;
		max-width: 1024px;
		min-height: 82px;
		padding: 0 1.25rem;
		width: 100%;
	}
	.brand {
		align-items: center;
		display: flex;
		gap: 0.8rem;
		text-decoration: none;
	}
	.brand img {
		filter: drop-shadow(0 10px 18px rgba(0, 0, 0, 0.3));
		width: 4.9rem;
	}
	.brand span {
		color: var(--snow);
		font-size: 0.85rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}
	ul {
		align-items: center;
		display: flex;
		gap: 0.55rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.language-switch {
		align-items: center;
		background: rgba(255, 255, 255, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 999px;
		display: flex;
		padding: 0.18rem;
	}
	.language-switch button {
		background: transparent;
		border: 0;
		border-radius: 999px;
		color: rgba(251, 251, 247, 0.7);
		cursor: pointer;
		font-size: 0.72rem;
		font-weight: 900;
		padding: 0.5rem 0.62rem;
	}
	.language-switch button[aria-pressed="true"] {
		background: var(--maple);
		color: #ffffff;
	}
	a {
		border-radius: 999px;
		color: rgba(251, 251, 247, 0.84);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		padding: 0.72rem 0.9rem;
		text-decoration: none;
		text-transform: uppercase;
		transition: background-color 180ms ease, color 180ms ease;
	}
	li a:hover,
	li a:focus-visible {
		background: rgba(255, 255, 255, 0.12);
		color: #ffffff;
	}
	@media (max-width: 720px) {
		.header {
			align-items: flex-start;
			flex-direction: column;
			gap: 0.85rem;
			padding-bottom: 1rem;
			padding-top: 1rem;
		}
		ul {
			flex-wrap: wrap;
			width: 100%;
		}
		.language-switch {
			position: absolute;
			right: 1.25rem;
			top: 1.3rem;
		}
		li a {
			display: inline-flex;
			font-size: 0.7rem;
			padding: 0.65rem 0.72rem;
		}
	}
</style>
