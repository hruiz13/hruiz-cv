---
const hobbies = [
  {
    titleEn: 'Aeromodelling',
    titleEs: 'Aeromodelismo',
    descriptionEn: 'Remote-control aircraft building, setup, and hands-on experimentation.',
    descriptionEs: 'He realizado aeromodelos a control remoto.'
  },
  {
    titleEn: 'Photography and video editing',
    titleEs: 'Fotografia y edicion de video',
    descriptionEn: 'Digital photography and video editing, supported by coursework and personal practice.',
    descriptionEs: 'Me gusta la fotografia digital y la edicion de video. He realizado cursos de esto.'
  },
  {
    titleEn: 'Digital woodworking',
    titleEs: 'Carpinteria digital',
    descriptionEn: 'Woodworking projects built with CNC machinery and digital fabrication processes.',
    descriptionEs: 'He realizado proyectos de carpinteria con tecnologia de maquinaria CNC.'
  }
];
---

<section class="hobbies-block">
  <div class="hobbies-block__header">
    <div class="hobbies-block__icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="34" height="34" viewBox="0 0 24 24" fill="none">
        <path d="M2 16.5 13.5 5l5.5 5.5L7.5 22H2v-5.5Z" fill="#38BDF8"></path>
        <path d="m14.2 4.3 1.5-1.5a2.12 2.12 0 0 1 3 0l2.5 2.5a2.12 2.12 0 0 1 0 3l-1.5 1.5-5.5-5.5Z" fill="#67E8F9"></path>
      </svg>
    </div>
    <div>
      <p class="hobbies-block__eyebrow" data-i18n data-en="Interests" data-es="Intereses">Interests</p>
      <h2>Hobbies</h2>
    </div>
  </div>

  <div class="hobbies-list">
    {hobbies.map((item) => (
      <article class="hobby-card">
        <h3 data-i18n data-en={item.titleEn} data-es={item.titleEs}>{item.titleEn}</h3>
        <p data-i18n data-en={item.descriptionEn} data-es={item.descriptionEs}>{item.descriptionEn}</p>
      </article>
    ))}
  </div>
</section>

<style>
  .hobbies-block {
    color: #102126;
    width: 100%;
  }

  .hobbies-block__header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .hobbies-block__icon {
    width: 4rem;
    height: 4rem;
    border-radius: 8px;
    background:
      linear-gradient(#102126, #102126) padding-box,
      linear-gradient(135deg, #4a7c59, #d8f3ff) border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
  }

  .hobbies-block__eyebrow {
    margin: 0 0 0.35rem;
    color: var(--maple);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.78rem;
    font-weight: 900;
  }

  .hobbies-block h2 {
    margin: 0;
    color: #102126;
    font-size: clamp(2rem, 4vw, 3.4rem);
    font-weight: 900;
    line-height: 1;
  }

  .hobbies-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 1rem;
  }

  .hobby-card {
    border-radius: 8px;
    background: #ffffff;
    border: 1px solid rgba(214, 40, 40, 0.16);
    padding: 1.35rem;
    box-shadow: 0 18px 45px rgba(16, 33, 38, 0.08);
  }

  .hobby-card h3 {
    margin: 0 0 0.75rem;
    color: #102126;
    font-size: 1.12rem;
    font-weight: 900;
  }

  .hobby-card p {
    margin: 0;
    color: #304247;
    line-height: 1.65;
  }
</style>
