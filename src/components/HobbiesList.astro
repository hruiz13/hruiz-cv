---
const hobbies = [
  {
    title: 'Aeromodelismo',
    description: 'He realizado aeromodelos a control remoto.'
  },
  {
    title: 'Fotografia y edicion de video',
    description: 'Me gusta la fotografia digital y la edicion de video. He realizado cursos de esto.'
  },
  {
    title: 'Carpinteria digital',
    description: 'He realizado proyectos de carpinteria con tecnologia de maquinaria CNC.'
  }
];
---

<section class="hobbies-block">
  <div class="hobbies-block__header">
    <div class="hobbies-block__icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="34" height="34" viewBox="0 0 24 24" fill="none">
        <path d="M2 16.5 13.5 5l5.5 5.5L7.5 22H2v-5.5Z" fill="#38BDF8"></path>
        <path d="m14.2 4.3 1.5-1.5a2.12 2.12 0 0 1 3 0l2.5 2.5a2.12 2.12 0 0 1 0 3l-1.5 1.5-5.5-5.5Z" fill="#67E8F9"></path>
      </svg>
    </div>
    <div>
      <p class="hobbies-block__eyebrow">Intereses</p>
      <h2>Hobbies</h2>
    </div>
  </div>

  <div class="hobbies-list">
    {hobbies.map((item) => (
      <article class="hobby-card">
        <h3>{item.title}</h3>
        <p>{item.description}</p>
      </article>
    ))}
  </div>
</section>

<style>
  .hobbies-block {
    width: 100%;
  }

  .hobbies-block__header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .hobbies-block__icon {
    width: 4rem;
    height: 4rem;
    border-radius: 1rem;
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.18), rgba(14, 165, 233, 0.16));
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .hobbies-block__eyebrow {
    margin: 0 0 0.35rem;
    color: #67e8f9;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.85rem;
  }

  .hobbies-block h2 {
    margin: 0;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
  }

  .hobbies-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .hobby-card {
    border-radius: 1.25rem;
    background: #3d3e42;
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 1.25rem;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.18);
  }

  .hobby-card h3 {
    margin: 0 0 0.75rem;
    font-size: 1.15rem;
  }

  .hobby-card p {
    margin: 0;
    color: #d8dde6;
    line-height: 1.65;
  }
</style>
