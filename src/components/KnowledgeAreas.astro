---
const knowledgeItems = [
  {
    titleEn: 'Laser machines',
    titleEs: 'Maquinas laser',
    descriptionEn:
      'Operation, alignment, maintenance, and basic electronics for laser cutting and engraving workflows.',
    descriptionEs:
      'Tengo conocimiento de manejo de maquinas laser, alineacion, mantenimiento y electronica de las mismas.'
  },
  {
    titleEn: 'CNC machines',
    titleEs: 'Maquinas CNC',
    descriptionEn:
      'G-code programming, machine operation, setup, and general maintenance for CNC production.',
    descriptionEs:
      'Cuento con conocimiento de programacion en Codigo G, manejo de la maquina y mantenimiento general.'
  },
  {
    titleEn: 'Arduino',
    titleEs: 'Arduino',
    descriptionEn:
      'Electronics projects based on Arduino, including board programming and prototype logic.',
    descriptionEs:
      'He realizado proyectos de electronica basados en Arduino, incluyendo la programacion de las placas.'
  }
];

const softwareTools = [
  'Corel Draw',
  'Adobe Illustrator',
  'Adobe Premiere',
  'Adobe Photoshop',
  'Adobe Lightroom',
  'Autocad (basico)',
  'Fusion 360 (basico)',
  'ArtCam'
];
---

<section class="knowledge-block">
  <div class="knowledge-block__header">
    <div class="knowledge-block__icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="34" height="34" viewBox="0 0 24 24" fill="none">
        <path d="M3 17.25V21h3.75L17.8 9.94l-3.75-3.75L3 17.25Z" fill="#60A5FA"></path>
        <path d="M14.06 4.94 17.81 8.69 19.65 6.85a1.25 1.25 0 0 0 0-1.77l-1.67-1.67a1.25 1.25 0 0 0-1.77 0l-2.15 2.15Z" fill="#93C5FD"></path>
      </svg>
    </div>
    <div>
      <p class="knowledge-block__eyebrow" data-i18n data-en="Knowledge" data-es="Conocimientos">Knowledge</p>
      <h2 data-i18n data-en="Hands-on technical range" data-es="Habilidades y conocimientos">Hands-on technical range</h2>
    </div>
  </div>

  <div class="knowledge-grid">
    {knowledgeItems.map((item) => (
      <article class="knowledge-card">
        <h3 data-i18n data-en={item.titleEn} data-es={item.titleEs}>{item.titleEn}</h3>
        <p data-i18n data-en={item.descriptionEn} data-es={item.descriptionEs}>{item.descriptionEn}</p>
      </article>
    ))}
  </div>

  <article class="knowledge-tools">
    <h3 data-i18n data-en="Creative and production software" data-es="Manejo de programas">Creative and production software</h3>
    <p data-i18n data-en="Tools I have used across design, fabrication, media, and technical production projects." data-es="Programas y herramientas que he utilizado en diferentes proyectos y procesos tecnicos.">Tools I have used across design, fabrication, media, and technical production projects.</p>
    <ul>
      {softwareTools.map((tool) => <li>{tool}</li>)}
    </ul>
  </article>
</section>

<style>
  .knowledge-block {
    background: #fbfbf7;
    border-radius: 8px;
    color: #102126;
    width: 100%;
  }

  .knowledge-block__header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .knowledge-block__icon {
    width: 4rem;
    height: 4rem;
    border-radius: 8px;
    background:
      linear-gradient(#102126, #102126) padding-box,
      linear-gradient(135deg, var(--maple), #ffb703) border-box;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
  }

  .knowledge-block__eyebrow {
    margin: 0 0 0.35rem;
    color: var(--maple);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.78rem;
    font-weight: 900;
  }

  .knowledge-block h2 {
    margin: 0;
    color: #102126;
    font-size: clamp(2rem, 4vw, 3.4rem);
    font-weight: 900;
    line-height: 1;
  }

  .knowledge-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 1rem;
  }

  .knowledge-card,
  .knowledge-tools {
    border-radius: 8px;
    background: #ffffff;
    border: 1px solid rgba(214, 40, 40, 0.16);
    padding: 1.35rem;
    box-shadow: 0 18px 45px rgba(16, 33, 38, 0.08);
  }

  .knowledge-card h3,
  .knowledge-tools h3 {
    margin: 0 0 0.75rem;
    color: #102126;
    font-size: 1.12rem;
    font-weight: 900;
  }

  .knowledge-card p,
  .knowledge-tools p {
    margin: 0;
    line-height: 1.65;
    color: #304247;
  }

  .knowledge-tools {
    margin-top: 1rem;
    background:
      radial-gradient(circle at 10% 0, rgba(216, 243, 255, 0.18), transparent 18rem),
      #102126;
    color: var(--snow);
  }

  .knowledge-tools h3 {
    color: var(--snow);
  }

  .knowledge-tools p {
    color: rgba(251, 251, 247, 0.78);
  }

  .knowledge-tools ul {
    margin: 1rem 0 0;
    padding-left: 1.25rem;
    columns: 2;
    column-gap: 2rem;
    line-height: 1.9;
    list-style: none;
  }

  .knowledge-tools li {
    color: var(--ice);
    font-weight: 800;
  }

  @media (max-width: 720px) {
    .knowledge-tools ul {
      columns: 1;
    }
  }
</style>
