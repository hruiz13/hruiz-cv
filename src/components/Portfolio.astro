    ],
  },
  'calendar-app': {
    summaryEn:
      'Calendar application for managing activities in residential communities.',
    bulletsEn: [
      'Administrative calendar for activity management.',
      'Interface based on Material UI.',
      'Backend support for event persistence.',
    ],
  },
  'e-commerce': {
    summaryEn:
      'E-commerce platform with shopping flows, payments, and an admin panel.',
    bulletsEn: [
      'User registration for purchases.',
      'Payment integrations with Mercado Pago and PayPal.',
      'Shopping cart with COP and USD support.',
      'Admin panel for users, categories, products, and sales.',
    ],
  },
  'weather-app': {
    summaryEn:
      'Weather app for searching forecasts by city, with detail views and temperature conversion.',
    bulletsEn: [
      'City-based search.',
      'Detailed result view.',
      'Unit switch between Celsius and Fahrenheit.',
    ],
  },
  'country-react-native': {
    summaryEn:
      'React Native adaptation of Country App for a mobile experience.',
    bulletsEn: [
      'Mobile version of Country App.',
      'Consumed an external countries API.',
