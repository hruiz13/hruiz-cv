---
import type { ImageMetadata } from 'astro';
import PortfolioCard from "./PortfolioCard.astro";
import { portfolioProjects } from '../data/portfolio';

const withBase = (path: string) => {
  if (/^(https?:)?\/\//.test(path)) return path;
  const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
  return `${base}${path.replace(/^\//, '')}`;
};

const resolveImage = (image: string | ImageMetadata) =>
  typeof image === 'string' ? withBase(image) : image.src;

const projects = portfolioProjects.map((project) => ({
  ...project,
  imageSrc: resolveImage(project.image),
  detailGallery: (project.details.gallery ?? []).map(withBase)
}));
---
<about class="mt-10">
    <div class='flex flex-col justify-around content-center about'>
        <h2 class="text-5xl font-bold">Portfolio</h2>
        <div class="flex flex-wrap items-center justify-center gap-10 my-20">
          {
            projects.map((project)=>
              <PortfolioCard 
                project={project}
              />
            )
          }
          </div>
    </div>
</about>
<style>
    about{
      background-color: #31333b;
    }
    .about {
      margin: auto;
      width: 100%;
		  max-width: 1024px;
	  }
</style>
