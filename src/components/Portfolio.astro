      'Set up a Linux server with LAMP, Node, MySQL, and RAID for the company.',
    ],
  },
};

const projects = portfolioProjects.map((project) => ({
  ...project,
  imageSrc: resolveImage(project.image),
  descriptionEn: portfolioCopy[project.id]?.en ?? project.description,
  descriptionEs: portfolioCopy[project.id]?.es ?? project.description,
  summaryEn: portfolioDetailsCopy[project.id]?.summaryEn ?? project.details.summary,
  summaryEs: project.details.summary,
  bulletsEn: portfolioDetailsCopy[project.id]?.bulletsEn ?? project.details.bullets,
  bulletsEs: project.details.bullets,
  detailGallery: (project.details.gallery ?? []).map(withBase)
}));
---
<section id="portfolio" class="portfolio-section">
    <div class="portfolio">
        <p class="section-kicker" data-i18n data-en="Recent work" data-es="Trabajo reciente">Recent work</p>
        <h2>Portfolio</h2>
        <div class="portfolio-grid">
          {
            projects.map((project)=>
              <PortfolioCard 
                project={project}
              />
            )
          }
          </div>
    </div>
</section>
<style>
    .portfolio-section {
      background: #102126;
      color: var(--snow);
      padding: 5.5rem 1.25rem;
    }
    .portfolio {
      margin: auto;
      width: 100%;
		  max-width: 1024px;
	  }
    .section-kicker {
      color: #ffb703;
      font-size: 0.78rem;
      font-weight: 900;
      letter-spacing: 0.18em;
      margin: 0 0 0.65rem;
      text-transform: uppercase;
    }
    h2 {
      color: var(--snow);
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 900;
      margin: 0 0 2rem;
    }
    .portfolio-grid {
      display: grid;
      gap: 1.1rem;
      grid-template-columns: repeat(auto-fit, minmax(15.5rem, 1fr));
    }
</style>
