---
import type { ImageMetadata } from 'astro';
import PortfolioCard from "./PortfolioCard.astro";
import { portfolioProjects } from '../data/portfolio';

const withBase = (path: string) => {
  if (/^(https?:)?\/\//.test(path)) return path;
  const base = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
  return `${base}${path.replace(/^\//, '')}`;
};

const resolveImage = (image: string | ImageMetadata) =>
  typeof image === 'string' ? withBase(image) : image.src;

const portfolioCopy: Record<string, { en: string; es: string }> = {
  'alfred-app': {
    en: 'Alfred mobile application.',
    es: 'Aplicacion de Alfred',
  },
  'alfred-web': {
    en: 'Official Alfred website.',
    es: 'Pagina oficil de alfred',
  },
  'jumbo-vtex': {
    en: 'Full rebuild of the website with VTEX IO technology.',
    es: 'Reconstruccion de la pagina totalmente con tecnologia VTEX-IO',
  },
  'hotel-management': {
    en: 'Application for hotel administration.',
    es: 'Aplicacion para administrar un hotel',
  },
  'country-app': {
    en: 'Country activities application.',
    es: 'Aplicacion de actividades en paises',
  },
  'batalla-naval': {
    en: 'Online two-player game.',
    es: 'Juego en linea para 2',
  },
  'calendar-app': {
    en: 'Calendar application.',
    es: 'Calendario',
  },
  'e-commerce': {
    en: 'Online store for digital commerce.',
    es: 'Tienda virtual de productos.',
