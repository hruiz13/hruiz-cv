---
import type { PortfolioProject } from '../data/portfolio';
import PortfolioModal from './PortfolioModal.astro';

interface Props {
	project: PortfolioProject & { imageSrc: string; detailGallery: string[] };
}

const { project } = Astro.props;
const modalId = `portfolio-modal-${project.id}`;
---
<article class="relative w-1/4 min-w-[260px] bg-gray-900 group h-72 flex items-end portfolio-card">
    <img class="absolute inset-0 object-cover w-full h-full opacity-90 group-hover:opacity-10" src={project.imageSrc} alt={project.title} />
    <div class="absolute inset-0 object-cover w-full h-full group-hover:opacity-0 flex items-center justify-center" >
        <div class='bg-slate-800 bg-opacity-60 rounded px-3'>{project.title}</div>
    </div>

    <div class="relative p-2">
    <div class="self-end">
        <div
        class="transition-all transform translate-y-8 opacity-0 group-hover:opacity-100 group-hover:translate-y-0">
        <div class="p-2">
            <div class='text-xl'>{project.title}</div>
            <p class="text-sm text-white">
            {project.description}
            </p>
            <p>{project.tech}</p>
            <button type="button" class="mt-5 px-4 py-2 rounded text-sm text-white bg-cyan-600 portfolio-card__button" data-dialog-open={modalId}>Ver mas</button>
        </div>
        </div>
    </div>
    </div>
</article>
<PortfolioModal project={project} />

<script>
  const lockBody = (locked) => {
    document.documentElement.style.overflow = locked ? 'hidden' : '';
  };

  document.querySelectorAll('[data-dialog-open]').forEach((button) => {
    button.addEventListener('click', () => {
      const dialogId = button.getAttribute('data-dialog-open');
      if (!dialogId) return;
      const dialog = document.getElementById(dialogId);
      if (!(dialog instanceof HTMLDialogElement)) return;
      dialog.showModal();
      lockBody(true);
    });
  });

  document.querySelectorAll('.portfolio-modal').forEach((dialog) => {
    if (!(dialog instanceof HTMLDialogElement)) return;

    dialog.querySelectorAll('[data-dialog-close]').forEach((button) => {
      button.addEventListener('click', () => {
        dialog.close();
      });
    });

    dialog.addEventListener('close', () => lockBody(false));

    dialog.addEventListener('click', (event) => {
      const rect = dialog.getBoundingClientRect();
      const inside =
        event.clientX >= rect.left &&
        event.clientX <= rect.right &&
        event.clientY >= rect.top &&
        event.clientY <= rect.bottom;
      if (!inside) dialog.close();
    });
  });
</script>
<style>
  .portfolio-card__button {
    cursor: pointer;
    border: 0;
  }
</style>
