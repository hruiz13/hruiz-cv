---
import type { PortfolioProject } from '../data/portfolio';

interface Props {
  project: PortfolioProject & { imageSrc: string; detailGallery: string[] };
}

const { project } = Astro.props;
const modalId = `portfolio-modal-${project.id}`;
---

<dialog id={modalId} class="portfolio-modal" aria-labelledby={`${modalId}-title`}>
  <div class="portfolio-modal__shell">
    <button type="button" class="portfolio-modal__close" data-dialog-close aria-label={`Cerrar detalle de ${project.title}`}>
      Cerrar
    </button>

    <div class="portfolio-modal__content">
      <div class="portfolio-modal__header">
        <p class="portfolio-modal__eyebrow">{project.tech}</p>
        <h3 id={`${modalId}-title`} class="portfolio-modal__title">{project.title}</h3>
        <p class="portfolio-modal__summary">{project.details.summary}</p>
      </div>

      <div class="portfolio-modal__section">
        <h4>Tecnologias</h4>
        <ul class="portfolio-modal__tags">
          {project.details.technologies.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <div class="portfolio-modal__section">
        <h4>Mas informacion</h4>
        <ul class="portfolio-modal__bullets">
          {project.details.bullets.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      {project.detailGallery.length > 0 && (
        <div class="portfolio-modal__section">
          <h4>Galeria</h4>
          <div class="portfolio-modal__gallery">
            {project.detailGallery.map((image) => (
              <img src={image} alt={`${project.title} captura`} loading="lazy" />
            ))}
          </div>
        </div>
      )}

      {(project.details.liveUrl || project.details.videoUrl) && (
        <div class="portfolio-modal__section">
          <h4>Enlaces</h4>
          <div class="portfolio-modal__links">
            {project.details.liveUrl && (
              <a href={project.details.liveUrl} target="_blank" rel="noopener noreferrer">
                {project.details.liveLabel ?? 'Ver proyecto'}
              </a>
            )}
            {project.details.videoUrl && (
              <a href={project.details.videoUrl.replace('/embed/', '/watch?v=')} target="_blank" rel="noopener noreferrer">
                Ver video
              </a>
            )}
          </div>
        </div>
      )}

      {project.details.videoUrl && (
        <div class="portfolio-modal__section">
          <h4>Demo</h4>
          <div class="portfolio-modal__video">
            <iframe
              src={project.details.videoUrl}
              title={`${project.title} video`}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            />
          </div>
        </div>
      )}
    </div>
  </div>
</dialog>

<style>
  .portfolio-modal {
    width: min(960px, calc(100vw - 2rem));
    max-height: calc(100vh - 2rem);
    padding: 0;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.25rem;
    background: #202228;
    color: #f4f7fb;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.45);
  }

  .portfolio-modal::backdrop {
    background: rgba(8, 10, 16, 0.78);
    backdrop-filter: blur(4px);
  }

  .portfolio-modal__shell {
    position: relative;
  }

  .portfolio-modal__close {
    position: sticky;
    top: 1rem;
    margin-left: auto;
    display: block;
    margin-right: 1rem;
    margin-top: 1rem;
    z-index: 1;
    border: 0;
    border-radius: 999px;
    background: #111827;
    color: #fff;
    padding: 0.65rem 1rem;
    cursor: pointer;
  }

  .portfolio-modal__content {
    padding: 0 1.25rem 1.5rem;
  }

  .portfolio-modal__header {
    margin-bottom: 1.5rem;
  }

  .portfolio-modal__eyebrow {
    margin: 0 0 0.75rem;
    color: #60a5fa;
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .portfolio-modal__title {
    margin: 0 0 0.75rem;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
  }

  .portfolio-modal__summary {
    margin: 0;
    color: #d2d8e2;
    line-height: 1.6;
  }

  .portfolio-modal__section + .portfolio-modal__section {
    margin-top: 1.75rem;
  }

  .portfolio-modal__section h4 {
    margin: 0 0 0.85rem;
    font-size: 1.05rem;
  }

  .portfolio-modal__tags,
  .portfolio-modal__bullets {
    margin: 0;
    padding-left: 1.25rem;
    color: #d9e0ea;
    line-height: 1.6;
  }

  .portfolio-modal__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    padding: 0;
    list-style: none;
  }

  .portfolio-modal__tags li {
    background: #2b313d;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .portfolio-modal__gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .portfolio-modal__gallery img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    border-radius: 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: #111827;
  }

  .portfolio-modal__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .portfolio-modal__links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 1rem;
    border-radius: 999px;
    background: #0f766e;
    color: #fff;
    text-decoration: none;
  }

  .portfolio-modal__video {
    overflow: hidden;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: #000;
    aspect-ratio: 16 / 9;
  }

  .portfolio-modal__video iframe {
    width: 100%;
    height: 100%;
    border: 0;
  }

  @media (max-width: 720px) {
    .portfolio-modal {
      width: calc(100vw - 1rem);
      max-height: calc(100vh - 1rem);
    }

    .portfolio-modal__content {
      padding: 0 0.9rem 1rem;
    }

    .portfolio-modal__gallery img {
      height: 180px;
    }
  }
</style>
