            </a>
        </div>
    </div>
    <div class="mountains" aria-hidden="true"></div>
</section>

<style>
    .profile-section {
        background:
            linear-gradient(180deg, rgba(7, 19, 22, 0.1), rgba(7, 19, 22, 0.85)),
            radial-gradient(circle at 76% 16%, rgba(214, 40, 40, 0.36), transparent 18rem);
        min-height: calc(100vh - 82px);
        overflow: hidden;
        position: relative;
    }
    .profile {
        align-items: center;
        display: grid;
        gap: 3rem;
        grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.75fr);
        margin: auto;
		max-width: 1024px;
        min-height: calc(100vh - 82px);
        padding: 5rem 1.25rem 7rem;
        position: relative;
        width: 100%;
        z-index: 1;
	}
    .aurora {
        background:
            linear-gradient(110deg, transparent 14%, rgba(122, 255, 209, 0.18) 28%, transparent 52%),
            linear-gradient(72deg, transparent 32%, rgba(216, 243, 255, 0.2) 48%, transparent 68%);
        filter: blur(12px);
        inset: 0;
        opacity: 0.9;
        position: absolute;
        transform: skewY(-8deg);
    }
    .eyebrow {
        color: var(--ice);
        font-size: 0.84rem;
        font-weight: 900;
        letter-spacing: 0.16em;
        margin: 0 0 1rem;
        text-transform: uppercase;
    }
    h1 {
        color: var(--snow);
        font-size: clamp(3.2rem, 8vw, 6.7rem);
        font-weight: 900;
        line-height: 0.93;
        margin: 0;
        max-width: 11ch;
    }
    h1 span {
        color: transparent;
        background: linear-gradient(120deg, #ffffff 0%, #d8f3ff 35%, #ff4d4d 82%);
        -webkit-background-clip: text;
        background-clip: text;
    }
    .lead {
        color: rgba(251, 251, 247, 0.82);
        font-size: 1.12rem;
        line-height: 1.75;
        margin: 1.4rem 0 0;
        max-width: 42rem;
    }
    .actions,
    .badges {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
        margin-top: 1.6rem;
    }
    .actions a,
    .badges span {
        border-radius: 999px;
        font-weight: 800;
        text-decoration: none;
    }
    .primary-action {
        background: var(--maple);
        box-shadow: 0 18px 36px rgba(214, 40, 40, 0.32);
        color: #ffffff;
        padding: 0.95rem 1.25rem;
    }
    .secondary-action {
        border: 1px solid rgba(255, 255, 255, 0.22);
        color: var(--snow);
        padding: 0.95rem 1.25rem;
    }
    .badges span {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.14);
        color: rgba(251, 251, 247, 0.84);
        font-size: 0.78rem;
        letter-spacing: 0.04em;
        padding: 0.55rem 0.8rem;
    }
    .portrait-wrap {
        align-self: end;
        background:
            linear-gradient(145deg, rgba(251, 251, 247, 0.2), rgba(251, 251, 247, 0.04)),
            linear-gradient(180deg, rgba(216, 243, 255, 0.15), rgba(214, 40, 40, 0.12));
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: 32px 32px 8px 8px;
        box-shadow: 0 34px 90px rgba(0, 0, 0, 0.34);
        min-height: 28rem;
        overflow: hidden;
        position: relative;
    }
    .portrait-wrap img {
        display: block;
        filter: grayscale(0.15) contrast(1.05);
        margin-left: auto;
        margin-top: 1.5rem;
        max-width: min(25rem, 100%);
        width: 100%;
    }
    .leaf {
        background: var(--maple);
        clip-path: polygon(50% 0, 60% 28%, 88% 18%, 72% 44%, 100% 52%, 68% 62%, 78% 92%, 50% 74%, 22% 92%, 32% 62%, 0 52%, 28% 44%, 12% 18%, 40% 28%);
        height: 3rem;
        position: absolute;
        right: 1.1rem;
        top: 1rem;
        width: 3rem;
    }
    .socials {
        align-items: center;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        position: absolute;
        right: 1.25rem;
        top: 50%;
        transform: translateY(-50%);
    }
    .socials::before {
        background: var(--maple);
        border-radius: 999px;
        content: "";
        height: 5rem;
        width: 2px;
    }
    .socials a {
        align-items: center;
        background: #102126;
        border: 1px solid rgba(255, 255, 255, 0.28);
        border-radius: 50%;
        box-shadow: 0 14px 28px rgba(0, 0, 0, 0.28);
        color: var(--snow);
        display: inline-flex;
        height: 2.75rem;
        justify-content: center;
        transition: transform 180ms ease, background-color 180ms ease;
        width: 2.75rem;
    }
    .socials a:hover {
        background: var(--maple);
        transform: translateY(-2px);
    }
    .mountains {
        background:
            linear-gradient(135deg, transparent 50%, #f5f2ea 50%) 0 100% / 30rem 9rem repeat-x,
            linear-gradient(225deg, transparent 50%, #fbfbf7 50%) 6rem 100% / 36rem 11rem repeat-x;
        bottom: -1px;
        height: 11rem;
        left: 0;
        position: absolute;
        right: 0;
    }
    @media (max-width: 900px) {
        .profile {
            grid-template-columns: 1fr;
            min-height: auto;
            padding-top: 4rem;
        }
        .portrait-wrap {
            justify-self: center;
            max-width: 24rem;
            min-height: 22rem;
            width: 100%;
        }
        .socials {
            flex-direction: row;
            position: static;
            transform: none;
        }
        .socials::before {
            height: 2px;
            width: 4rem;
        }
    }
    @media (max-width: 540px) {
        h1 {
            font-size: 3.3rem;
        }
        .profile {
            padding-bottom: 6rem;
        }
    }
</style>
