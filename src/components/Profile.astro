---
import Hruiz from '../assets/images/hruiz.png';
---
<section class="profile-section">
    <div class="aurora" aria-hidden="true"></div>
    <div class="profile">
        <div class="copy">
            <p class="eyebrow" data-i18n data-en="Frontend developer with a Canadian edge" data-es="Frontend developer con vibra canadiense">Frontend developer with a Canadian edge</p>
            <h1><span data-i18n data-en="I'm" data-es="Soy">I'm</span> <span>Hector Ruiz</span></h1>
            <p class="lead" data-i18n data-en="I build fast, clear, and resilient web experiences: from e-commerce to admin apps, with product thinking and frontend craft." data-es="Construyo experiencias web rapidas, claras y solidas: de e-commerce a apps administrativas, con mentalidad de producto y oficio frontend.">
                I build fast, clear, and resilient web experiences: from e-commerce to admin apps, with product thinking and frontend craft.
            </p>
            <div class="actions">
                <a class="primary-action" href="#portfolio" data-i18n data-en="View projects" data-es="Ver proyectos">View projects</a>
                <a class="secondary-action" href="mailto:hruiz.com@gmail.com" data-i18n data-en="Contact me" data-es="Contactame">Contact me</a>
            </div>
            <div class="badges" aria-label="Highlights">
                <span>React</span>
                <span>VTEX IO</span>
                <span>TypeScript</span>
                <span>UI craft</span>
            </div>
        </div>
        <div class="portrait-wrap">
            <div class="leaf" aria-hidden="true"></div>
            <img src={Hruiz.src} alt="Hector Ruiz" />
        </div>
        <div class="socials" aria-label="Social links">
            <a href="https://www.linkedin.com/in/hector-ruiz-13935141/" target="_blank" rel="noopener" aria-label="LinkedIn">
